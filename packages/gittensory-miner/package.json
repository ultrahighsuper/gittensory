  "license": "AGPL-3.0-only",
  "type": "module",
  "description": "Foundation CLI for the local Gittensory miner runtime.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JSONbored/gittensory.git",
    "directory": "packages/gittensory-miner"
  },
